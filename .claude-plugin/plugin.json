{
  "name": "laconic",
  "description": "Laconic mode. Spartan brevity. Auto-active per session.",
  "author": { "name": "VG" },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/activate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
